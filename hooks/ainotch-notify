#!/usr/bin/env python3
"""Avisa a ilha que um CLI mudou de estado (fim de ciclo, pedido, etc).

Fala tres dialetos:
  - Claude Code / Gemini / Antigravity: payload JSON no stdin
  - Codex: payload JSON no argv[1] (mecanismo `notify` do config.toml)

Nao bloqueia: manda a mensagem, espera uns segundos pra dar tempo de
ler e fecha a ilha. Quem e (source) vem da env AINOTCH_SOURCE.
"""
import json
import os
import socket
import subprocess
import sys
import tempfile
import time

HOST = "127.0.0.1"
PORT = 8123
CONNECT_TIMEOUT = 0.5
TEMPO_NA_TELA = 5  # segundos antes de fechar sozinho

NOMES = {
    "claude": "Claude Code",
    "gemini": "Gemini",
    "antigravity": "Antigravity",
    "codex": "Codex",
}

# Eventos que so registram presenca: manda e sai, sem esperar nem
# recolher a ilha -- e um "oi, existo", nao um "acabei".
SO_REGISTRA = {"SessionStart"}

# Batimento cardiaco: a cada tool call ou prompt, atualiza a linha da
# sessao sem abrir banner nem recolher nada. Leve de proposito -- roda
# dezenas de vezes por conversa, entao nada de ler transcript ou quota.
ATIVIDADE = {"PostToolUse", "UserPromptSubmit"}

# evento -> (state, verbo). Cobre Claude, Gemini/Antigravity e Codex.
ESTADOS = {
    # Claude Code
    "SessionStart": ("working", "abriu"),
    "UserPromptSubmit": ("working", "trabalhando"),
    "Stop": ("idle", "terminou"),
    "StopFailure": ("erro", "parou com erro"),
    "SubagentStop": ("idle", "subagente terminou"),
    # Gemini / Antigravity
    "AfterAgent": ("idle", "terminou"),
    "Notification": ("pedido", "precisa de você"),
    # ambos
    "SessionEnd": ("offline", "sessão encerrada"),
    # Codex (campo "type" do notify)
    "agent-turn-complete": ("idle", "terminou"),
}


def enviar(payload):
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(CONNECT_TIMEOUT)
    try:
        s.connect((HOST, PORT))
        s.sendall(json.dumps(payload).encode())
    except OSError:
        return False
    finally:
        s.close()
    return True


CACHE_USO = os.path.join(tempfile.gettempdir(), "ainotch-usage.json")


def uso():
    """Utilizacao 5h/7d da conta Claude, ou None se nao der.

    Mesmo caminho que o /usage do CLI: token OAuth no Keychain + endpoint
    oauth/usage. Cache de 60s pra nao bater na API a cada prompt."""
    try:
        with open(CACHE_USO) as f:
            guardado = json.load(f)
        if time.time() - guardado.get("ts", 0) < 60:
            return guardado.get("usage")
    except (OSError, ValueError):
        pass

    try:
        credencial = subprocess.run(
            ["security", "find-generic-password",
             "-s", "Claude Code-credentials", "-w"],
            capture_output=True, text=True, timeout=3,
        ).stdout
        token = json.loads(credencial)["claudeAiOauth"]["accessToken"]

        bruto = subprocess.run(
            ["curl", "-s", "-m", "4",
             "https://api.anthropic.com/api/oauth/usage",
             "-H", f"Authorization: Bearer {token}",
             "-H", "anthropic-beta: oauth-2025-04-20"],
            capture_output=True, text=True, timeout=6,
        ).stdout
        dados = json.loads(bruto)

        resultado = {
            "five": (dados.get("five_hour") or {}).get("utilization"),
            "seven": (dados.get("seven_day") or {}).get("utilization"),
            "seven_resets": (dados.get("seven_day") or {}).get("resets_at") or "",
        }
    except (OSError, ValueError, KeyError, subprocess.SubprocessError):
        return None

    try:
        with open(CACHE_USO, "w") as f:
            json.dump({"ts": time.time(), "usage": resultado}, f)
    except OSError:
        pass
    return resultado


def descobrir_tty():
    """Qual terminal esta rodando este CLI, pra ilha saber pra onde pular.

    O hook nasce sem tty (o Claude Code o solta do terminal), entao sobe
    a arvore de processos ate achar quem tem: o proprio `claude`."""
    pid = os.getpid()
    for _ in range(8):
        try:
            saida = subprocess.run(
                ["ps", "-o", "ppid=,tty=", "-p", str(pid)],
                capture_output=True, text=True, timeout=2,
            ).stdout.split()
        except (OSError, subprocess.SubprocessError):
            return ""

        if len(saida) < 2:
            return ""
        ppid, tty = saida[0], saida[1]
        if tty != "??":
            return f"/dev/{tty}"

        try:
            pid = int(ppid)
        except ValueError:
            return ""
        if pid <= 1:
            return ""
    return ""


def do_transcript(caminho):
    """Le o .jsonl da sessao e devolve (titulo, ultima_fala, modelo).

    O titulo e o mesmo que o Claude Code poe na aba do terminal: ele
    grava uma linha {"type":"ai-title","aiTitle":...} e reescreve
    conforme a conversa muda de assunto -- por isso vale a ultima.
    O modelo sai do ultimo turno do assistente (message.model), pra
    ilha mostrar badge (Opus 4.8 / Fable 5) e distinguir sessoes."""
    titulo, ultima, modelo = "", "", ""
    if not caminho:
        return titulo, ultima, modelo

    try:
        with open(caminho, errors="ignore") as f:
            for linha in f:
                try:
                    dados = json.loads(linha)
                except ValueError:
                    continue

                tipo = dados.get("type")
                if tipo == "ai-title":
                    titulo = dados.get("aiTitle") or titulo
                elif tipo == "assistant":
                    msg = dados.get("message") or {}
                    modelo = msg.get("model") or modelo
                    blocos = msg.get("content") or []
                    for bloco in blocos:
                        if not isinstance(bloco, dict):
                            continue
                        if bloco.get("type") != "text":
                            continue
                        texto = (bloco.get("text") or "").strip()
                        if texto:
                            ultima = texto
    except OSError:
        pass

    return titulo, ultima, modelo


def frase(texto, limite=130):
    """Ultima linha util da fala, limpa de markdown pra caber na ilha.

    A ultima linha costuma ser o fecho ("commitei X, quer que eu Y?"),
    que e justamente o que diz se acabou e o que ficou pendente."""
    linhas = [l.strip() for l in str(texto).splitlines() if l.strip()]
    if not linhas:
        return ""

    linha = linhas[-1]
    for lixo in ("**", "`", "##", "#"):
        linha = linha.replace(lixo, "")
    linha = linha.lstrip("-*> ").strip()
    linha = " ".join(linha.split())

    if len(linha) > limite:
        linha = linha[: limite - 3] + "..."
    return linha


def linha_de_atividade(entrada):
    """O que a sessao esta fazendo agora, curto o bastante pra ilha."""
    tool = entrada.get("tool_name", "")
    dados = entrada.get("tool_input") or {}

    if tool == "Bash":
        detalhe = dados.get("command", "")
    elif tool in ("Read", "Edit", "Write", "NotebookEdit"):
        detalhe = os.path.basename(str(dados.get("file_path", "")))
    elif tool == "WebFetch":
        detalhe = dados.get("url", "")
    elif tool in ("Grep", "Glob"):
        detalhe = dados.get("pattern", "")
    else:
        detalhe = ""

    detalhe = " ".join(str(detalhe).split())
    if len(detalhe) > 70:
        detalhe = detalhe[:67] + "..."

    return f"{tool}: {detalhe}" if detalhe else (tool or "…")


def ler_payload():
    """Codex manda por argv, o resto por stdin."""
    bruto = sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read()
    try:
        dados = json.loads(bruto or "{}")
        return dados if isinstance(dados, dict) else {}
    except ValueError:
        return {}


def main():
    entrada = ler_payload()

    evento = entrada.get("hook_event_name") or entrada.get("type") or "Stop"
    estado, verbo = ESTADOS.get(evento, ("idle", "terminou"))

    fonte = os.environ.get("AINOTCH_SOURCE", "claude")
    nome = NOMES.get(fonte, fonte)
    projeto = os.path.basename(entrada.get("cwd") or os.getcwd())

    # Batimento: atualiza a linha e sai. Nada de transcript, quota,
    # banner ou close -- isso roda a cada tool call.
    if evento in ATIVIDADE:
        if evento == "UserPromptSubmit":
            extra = " ".join(str(entrada.get("prompt", "")).split())
            if len(extra) > 90:
                extra = extra[:87] + "..."
            extra = f"Você: {extra}" if extra else "…"
        else:
            extra = linha_de_atividade(entrada)

        pacote = {
            "type": "activity",
            "message": f"{nome} trabalhando\n{extra}",
            "project": projeto,
            "source": fonte,
            "state": "working",
            "session": entrada.get("session_id", ""),
            "tty": descobrir_tty(),
            "term": os.environ.get("TERM_PROGRAM", ""),
        }
        # O prompt fica guardado na sessao ("Você: ...") mesmo depois
        # que os batimentos de tool call passarem por cima da mensagem.
        if evento == "UserPromptSubmit":
            pacote["prompt"] = extra
        # Um turno longo dispara dezenas de batimentos e nenhum Stop:
        # sem isso a capsula de quota congela justo enquanto o CLI mais
        # gasta. O cache de 60s do uso() segura o custo.
        if fonte == "claude":
            pacote["usage"] = uso()
        enviar(pacote)
        return

    # Claude Code so manda o caminho do transcript: titulo e ultima fala
    # saem de la. Gemini e Codex ja mandam o texto pronto no payload.
    titulo, ultima_fala, modelo = do_transcript(entrada.get("transcript_path"))
    extra = frase(
        entrada.get("message")
        or entrada.get("last-assistant-message")
        or ultima_fala
    )

    # Sem titulo (conversa curta demais pro Claude nomear), a pasta serve.
    if not titulo:
        titulo = projeto

    linha = f"{nome} {verbo}"
    if extra:
        linha += f"\n{extra}"

    ok = enviar({
        "type": "message",
        "message": linha,
        "title": titulo,
        "project": projeto,
        "source": fonte,
        "state": estado,
        "session": entrada.get("session_id", ""),
        "tty": descobrir_tty(),
        "term": os.environ.get("TERM_PROGRAM", ""),
        "model": modelo,
        # So o Claude tem esse endpoint; os outros CLIs mandam None e a
        # ilha simplesmente mantem o ultimo valor que viu.
        "usage": uso() if fonte == "claude" else None,
    })
    if not ok:
        return  # app fechado, nada a fazer

    # "Oi, existo" entra na lista mas nao merece banner de 5s na tela:
    # recolhe ja. O close mantem a sessao na lista.
    if evento not in SO_REGISTRA:
        time.sleep(TEMPO_NA_TELA)
    # Sem o id, a ilha nao sabe qual sessao recolher e todas ficavam
    # acumuladas na lista pra sempre.
    enviar({
        "type": "close",
        "session": entrada.get("session_id", ""),
        "source": fonte,
    })


if __name__ == "__main__":
    main()
