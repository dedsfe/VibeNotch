#!/usr/bin/env python3
"""Ponte entre o Claude Code e o AINotch (Vibe Island caseiro).

Recebe o payload do hook no stdin, manda o pedido de permissao pro app
na porta 8123 e espera o clique na ilha: Allow, Sempre ou Deny.

"Sempre" grava uma regra em ~/.claude/settings.local.json. A partir dai
o proprio Claude Code aprova sozinho e este hook nem chega a rodar.

Se o app nao estiver rodando, sai calado -> o Claude Code mostra o
prompt normal no terminal. Nunca bloqueia por conta propria.
"""
import json
import os
import socket
import subprocess
import sys
import tempfile
from urllib.parse import urlparse

HOST = "127.0.0.1"
PORT = 8123
CONNECT_TIMEOUT = 0.5   # app no ar ou nao: decide rapido
ANSWER_TIMEOUT = 3600   # tempo pro Andre clicar

SETTINGS = os.path.expanduser("~/.claude/settings.local.json")

# Estas nao sao permissao sim/nao: pedem uma escolha ou um texto.
# Allow/Deny na ilha nao responderia nada e a pergunta ficaria travada
# no terminal -- entao deixa passar direto pro Claude Code.
TOOLS_IGNORADAS = {"AskUserQuestion", "ExitPlanMode"}

# Comandos onde o primeiro token e generico demais: liberar "git" inteiro
# e cheque em branco, "git status" e especifico. Nestes a regra leva o
# subcomando junto.
COM_SUBCOMANDO = {
    "git", "gh", "npm", "npx", "yarn", "pnpm", "cargo", "brew", "docker",
    "kubectl", "pip", "pip3", "python", "python3", "go", "swift", "xcrun",
    "bundle", "make", "vercel", "supabase",
}

# Se o comando tem qualquer um destes, ele encadeia outra coisa e o
# primeiro token nao representa o que vai rodar de fato. Sem regra.
PERIGOSOS = ("|", "&&", "||", ";", ">", "<", "$(", "`", "\n")

FERRAMENTAS_DE_ARQUIVO = ("Read", "Edit", "Write", "NotebookEdit")


def resumo(payload):
    """Monta uma linha curta que cabe na ilha."""
    tool = payload.get("tool_name", "?")
    entrada = payload.get("tool_input") or {}

    if tool == "Bash":
        detalhe = entrada.get("command", "")
    elif tool in FERRAMENTAS_DE_ARQUIVO:
        detalhe = entrada.get("file_path", "")
    elif tool == "WebFetch":
        detalhe = entrada.get("url", "")
    else:
        detalhe = json.dumps(entrada, ensure_ascii=False)

    detalhe = " ".join(str(detalhe).split())
    if len(detalhe) > 160:
        detalhe = detalhe[:157] + "..."

    return f"{tool}: {detalhe}" if detalhe else tool


def regra(payload):
    """Regra de permissao pro botao "Sempre", ou "" se nao der pra gerar
    uma que seja estreita o suficiente pra ser segura.

    String vazia = a ilha esconde o botao. Melhor nao oferecer do que
    oferecer um curinga que libera meio sistema num clique."""
    tool = payload.get("tool_name", "")
    entrada = payload.get("tool_input") or {}

    if tool == "Bash":
        comando = str(entrada.get("command", "")).strip()
        if not comando or any(p in comando for p in PERIGOSOS):
            return ""
        tokens = comando.split()
        base = tokens[0]
        if base in COM_SUBCOMANDO:
            # sem subcomando nomeado nao da pra estreitar: nao oferece
            if len(tokens) < 2 or tokens[1].startswith("-"):
                return ""
            base = f"{base} {tokens[1]}"
        return f"Bash({base}:*)"

    if tool == "WebFetch":
        host = urlparse(str(entrada.get("url", ""))).hostname
        return f"WebFetch(domain:{host})" if host else ""

    if tool in FERRAMENTAS_DE_ARQUIVO:
        caminho = str(entrada.get("file_path", ""))
        pasta = os.path.dirname(caminho)
        if not pasta or pasta == "/":
            return ""
        # caminho absoluto no formato do Claude Code: Edit(//pasta/**)
        return f"{tool}(//{pasta.lstrip('/')}/**)"

    return ""


def gravar_regra(nova):
    """Adiciona a regra em permissions.allow. Escrita atomica pra nao
    torrar o settings se algo explodir no meio."""
    try:
        with open(SETTINGS) as f:
            dados = json.load(f)
    except (OSError, ValueError):
        dados = {}

    permissoes = dados.setdefault("permissions", {})
    liberadas = permissoes.setdefault("allow", [])
    if nova in liberadas:
        return
    liberadas.append(nova)

    pasta = os.path.dirname(SETTINGS)
    try:
        fd, temporario = tempfile.mkstemp(dir=pasta, suffix=".tmp")
        with os.fdopen(fd, "w") as f:
            json.dump(dados, f, indent=2, ensure_ascii=False)
            f.write("\n")
        os.replace(temporario, SETTINGS)
    except OSError:
        pass  # sem permissao gravada, mas a acao desta vez ja foi aprovada


def descobrir_tty():
    """Qual terminal esta rodando este CLI, pra ilha saber pra onde pular.

    O hook nasce sem tty (o Claude Code o solta do terminal), entao sobe
    a arvore de processos ate achar quem tem: o proprio `claude`."""
    pid = os.getpid()
    for _ in range(8):
        try:
            saida = subprocess.run(
                ["ps", "-o", "ppid=,tty=", "-p", str(pid)],
                capture_output=True, text=True, timeout=2,
            ).stdout.split()
        except (OSError, subprocess.SubprocessError):
            return ""

        if len(saida) < 2:
            return ""
        ppid, tty = saida[0], saida[1]
        if tty != "??":
            return f"/dev/{tty}"

        try:
            pid = int(ppid)
        except ValueError:
            return ""
        if pid <= 1:
            return ""
    return ""


def perguntar(texto, permissao):
    """Devolve "allow", "always", "deny" ou None (app fora do ar)."""
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(CONNECT_TIMEOUT)
    try:
        s.connect((HOST, PORT))
    except OSError:
        return None

    try:
        s.sendall(json.dumps({
            "type": "prompt",
            "message": texto,
            "rule": permissao,
            "tty": descobrir_tty(),
            "term": os.environ.get("TERM_PROGRAM", ""),
        }).encode())
        s.settimeout(ANSWER_TIMEOUT)
        resposta = s.recv(1024).decode().strip().lower()
    except OSError:
        return None
    finally:
        s.close()

    if resposta.startswith("a"):
        return "always"
    if resposta.startswith("y"):
        return "allow"
    if resposta.startswith("n"):
        return "deny"
    return None


def main():
    try:
        payload = json.loads(sys.stdin.read() or "{}")
    except ValueError:
        return

    if payload.get("tool_name") in TOOLS_IGNORADAS:
        return

    permissao = regra(payload)
    decisao = perguntar(resumo(payload), permissao)
    if decisao is None:
        return  # sem saida = Claude Code pergunta do jeito dele

    if decisao == "always" and permissao:
        gravar_regra(permissao)

    # PermissionRequest tem schema proprio: decision.behavior, e nao o
    # permissionDecision do PreToolUse. Com o campo errado o Claude Code
    # ignora a resposta em silencio e o clique na ilha nao faz nada.
    json.dump({
        "hookSpecificOutput": {
            "hookEventName": "PermissionRequest",
            "decision": {"behavior": "deny" if decisao == "deny" else "allow"},
        }
    }, sys.stdout)


if __name__ == "__main__":
    main()
